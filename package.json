{
  "name": "pi-tobis-extensions",
  "version": "0.1.0",
  "description": "Tobi's custom pi extensions — selective install via package filtering.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "extensions",
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "npx tsx --test extensions/telegram/test-relay.ts extensions/telegram/test-session-registry.ts extensions/telegram/test-state.ts extensions/telegram/test-topics.ts extensions/telegram/test-outgoing.ts",
    "test:integration": "npx tsx extensions/telegram/test-media.ts",
    "typecheck": "npx tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/telegram/index.ts",
      "./extensions/permissions/index.ts",
      "./extensions/checkpoint/index.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
